<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp">

    <!-- Avatar -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cv_avatar"
        android:layout_width="56dp"
        android:layout_height="56dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="?attr/colorPrimaryContainer"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:strokeWidth="0dp">

        <TextView
            android:id="@+id/tv_avatar_monogram"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="A"
            android:textColor="?attr/colorOnPrimaryContainer"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/iv_avatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:visibility="gone" />

    </com.google.android.material.card.MaterialCardView>

    <!-- Online Indicator -->
    <View
        android:id="@+id/view_online_indicator"
        android:layout_width="12dp"
        android:layout_height="12dp"
        android:background="@drawable/bg_online_indicator"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/cv_avatar"
        app:layout_constraintEnd_toEndOf="@id/cv_avatar"
        tools:visibility="visible" />

    <!-- Chat Name -->
    <TextView
        android:id="@+id/tv_chat_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="John Doe"
        android:textColor="?attr/colorOnSurface"
        android:textSize="17sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/tv_time"
        app:layout_constraintStart_toEndOf="@id/cv_avatar"
        app:layout_constraintTop_toTopOf="@id/cv_avatar"
        app:layout_constraintVertical_chainStyle="packed" />

    <ImageView
        android:id="@+id/iv_verified"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_marginStart="4dp"
        android:src="@drawable/ic_verified"
        android:tint="?attr/colorPrimary"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/tv_chat_name"
        app:layout_constraintStart_toEndOf="@id/tv_chat_name"
        app:layout_constraintTop_toTopOf="@id/tv_chat_name"
        tools:visibility="visible" />

    <!-- Last Message -->
    <TextView
        android:id="@+id/tv_last_message"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:text="Hey, how are you doing today?"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:textSize="15sp"
        app:layout_constraintEnd_toStartOf="@id/layout_indicators"
        app:layout_constraintStart_toStartOf="@id/tv_chat_name"
        app:layout_constraintTop_toBottomOf="@id/tv_chat_name" />

    <!-- Time -->
    <TextView
        android:id="@+id/tv_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="12:45"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tv_chat_name" />

    <!-- Indicators (Unread, Muted, Pinned) -->
    <LinearLayout
        android:id="@+id/layout_indicators"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical|end"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_time">

        <ImageView
            android:id="@+id/iv_muted"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginEnd="4dp"
            android:src="@drawable/ic_notifications_off"
            android:tint="?attr/colorOnSurfaceVariant"
            android:visibility="gone"
            tools:visibility="visible" />

        <ImageView
            android:id="@+id/iv_forum"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginEnd="4dp"
            android:src="@drawable/ic_chat"
            android:tint="?attr/colorOnSurfaceVariant"
            android:visibility="gone"
            tools:visibility="visible" />

        <ImageView
            android:id="@+id/iv_pinned"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginEnd="8dp"
            android:rotation="45"
            android:src="@drawable/ic_push_pin"
            android:tint="?attr/colorOnSurfaceVariant"
            android:visibility="gone"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/tv_unread_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_unread_count"
            android:gravity="center"
            android:minWidth="22dp"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:text="5"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone"
            tools:visibility="visible" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#E0E0E0"
        app:layout_constraintTop_toBottomOf="@id/cv_avatar"
        android:layout_marginTop="12dp"
        android:layout_marginStart="80dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
